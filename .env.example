# Copy this file to .env and fill in the values you have. Nothing here is
# a real secret. See app/config/settings.py for how each variable is used.

# --- General -----------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
# When MOCK_MODE=true, the whole pipeline runs on deterministic fixture
# content with zero API calls — no keys required. Useful for demos/tests.
MOCK_MODE=false

# --- LLM provider defaults (see app/llm/factory.py) ---------------------
# One of: groq, openrouter
LLM_DEFAULT_PROVIDER=groq
LLM_DEFAULT_MODEL=llama-3.1-8b-instant
LLM_MAX_RETRIES=2
LLM_REQUEST_TIMEOUT_SECONDS=60

# A team commonly has several free-tier keys (one per member). All
# configured keys are tried in order before moving to the next provider —
# e.g. GROQ_API_KEY -> GROQ_API_KEY1 -> GROQ_API_KEY2 -> GROQ_API_KEY3 ->
# OPENROUTER_API_KEY -> ... -> OPENROUTER_API_KEY4 -> deterministic
# fallback content. Leave any of these blank if you only have one key.
GROQ_API_KEY=
GROQ_API_KEY1=
GROQ_API_KEY2=
GROQ_API_KEY3=

# Model used for the OpenRouter fallback attempts (only reached if every
# Groq key above fails or is rate-limited).
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=
OPENROUTER_API_KEY1=
OPENROUTER_API_KEY2=
OPENROUTER_API_KEY3=
OPENROUTER_API_KEY4=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=AI Marketing Team

# --- Optional per-agent overrides ---------------------------------------
# Leave blank to use the global default above for that agent.
MARKET_INTELLIGENCE_PROVIDER=
MARKET_INTELLIGENCE_MODEL=
CAMPAIGN_STRATEGY_PROVIDER=
CAMPAIGN_STRATEGY_MODEL=
CONTENT_GENERATION_PROVIDER=
CONTENT_GENERATION_MODEL=
QUALITY_ASSURANCE_PROVIDER=
QUALITY_ASSURANCE_MODEL=

# --- Search providers (see app/search) ----------------------------------
TAVILY_API_KEY=
SERPER_API_KEY=
SEARCH_MAX_RESULTS=5
SEARCH_REQUEST_TIMEOUT_SECONDS=20

# --- API server ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Origins allowed to call this API. The React frontend (frontend/) is a
# separate deployable (Netlify) talking to this API over CORS — see
# frontend/.env.example for its own VITE_API_BASE_URL setting.
CORS_ALLOW_ORIGINS=*
